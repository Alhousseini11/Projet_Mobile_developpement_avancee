# Local backend variables for `npm run dev` and `npm test`.
# This DATABASE_URL targets the postgres port exposed by docker-compose on the host.
DATABASE_URL=postgresql://mon_user:change-me-dev-password@localhost:5433/mon_app?schema=public
PORT=3000
JWT_SECRET=replace-me-for-local-dev
SENDGRID_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Garage Mechanic
PASSWORD_RESET_URL=http://localhost:3000/reset-password
STRIPE_KEY=
STRIPE_SUCCESS_URL=https://example.com/garage/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://example.com/garage/stripe/cancel
PUBLIC_BASE_URL=http://localhost:3000
S3_BUCKET=
AWS_REGION=us-east-1
GOOGLE_MAPS_KEY=
# Keep disabled by default. Enable explicitly for local demo account testing only.
DEMO_MODE=false
