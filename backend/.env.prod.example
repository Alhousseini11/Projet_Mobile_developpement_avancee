# Backend runtime variables for the production container.
# DATABASE_URL is injected by docker-compose from .env.prod at runtime.
PORT=3000
JWT_SECRET=replace-with-long-random-secret
SENDGRID_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Garage Mechanic
PASSWORD_RESET_URL=https://api.example.com/reset-password
STRIPE_KEY=
STRIPE_SUCCESS_URL=https://example.com/garage/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://example.com/garage/stripe/cancel
PUBLIC_BASE_URL=https://api.example.com
S3_BUCKET=
AWS_REGION=us-east-1
GOOGLE_MAPS_KEY=
# Must stay disabled in production.
DEMO_MODE=false
