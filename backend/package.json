{
  "name": "garage-mechanic-backend",
  "version": "0.0.1",
  "main": "dist/server.js",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p .",
    "test:build": "tsc -p tsconfig.test.json",
    "test": "npm run test:build && node --test dist-test/tests/*.test.js",
    "test:coverage": "npm run test:build && node --experimental-test-coverage --test-coverage-include=dist-test/src/**/*.js --test-coverage-exclude=dist-test/src/**/*.routes.js --test-coverage-exclude=dist-test/src/modules/chat/**/*.js --test-coverage-exclude=dist-test/src/modules/emergency/**/*.js --test-coverage-exclude=dist-test/src/modules/estimation/**/*.js --test-coverage-exclude=dist-test/src/modules/location/**/*.js --test-coverage-exclude=dist-test/src/config/env.js --test-coverage-exclude=dist-test/src/data/stripe/stripeClient.js --test dist-test/tests/*.test.js",
    "test:coverage:ci": "npm run test:build && node --experimental-test-coverage --test-coverage-include=dist-test/src/**/*.js --test-coverage-exclude=dist-test/src/**/*.routes.js --test-coverage-exclude=dist-test/src/modules/chat/**/*.js --test-coverage-exclude=dist-test/src/modules/emergency/**/*.js --test-coverage-exclude=dist-test/src/modules/estimation/**/*.js --test-coverage-exclude=dist-test/src/modules/location/**/*.js --test-coverage-exclude=dist-test/src/config/env.js --test-coverage-exclude=dist-test/src/data/stripe/stripeClient.js --test-coverage-lines=80 --test-coverage-functions=90 --test-coverage-branches=75 --test dist-test/tests/*.test.js",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.884.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "7.4.1",
    "@sendgrid/mail": "^8.1.6",
    "aws-sdk": "^2.1491.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "socket.io": "^4.7.5",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.18.0",
    "eslint": "^8.57.0",
    "prisma": "7.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
