datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  MECHANIC
  ADMIN
}

enum ReservationStatus {
  PENDING
  ASSIGNED
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

enum NotificationType {
  APPOINTMENT
  PROMO
  MAINTENANCE
  SYSTEM
}

enum Severity {
  INFO
  WARN
  CRITICAL
}

enum TutorialDifficulty {
  EASY
  MEDIUM
  HARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  passwordHash         String
  fullName             String
  firstName            String?
  lastName             String?
  phoneNumber          String?
  phone                String?
  role                 Role            @default(USER)
  photoUrl             String?
  profilePicture       String?
  vehicles             Vehicle[]
  reservations         Reservation[]
  assignedReservations Reservation[]   @relation("MechanicReservations")
  reviews              Review[]
  favorites            Favorite[]
  quotes               Quote[]
  payments             PaymentMethod[]
  notifications        Notification[]
  messagesSent         ChatMessage[]   @relation("MessagesSent")
  messagesReceived     ChatMessage[]   @relation("MessagesReceived")
  reminders            Reminder[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Vehicle {
  id           String        @id @default(cuid())
  userId       String
  brand        String
  model        String
  year         Int
  licensePlate String?
  color        String?
  mileage      Int?
  photoUrl     String?
  reminders    Reminder[]
  reservations Reservation[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reservation {
  id                 String            @id @default(cuid())
  userId             String
  vehicleId          String
  mechanicId         String?
  assignedMechanicId String?
  serviceType        String
  description        String?
  status             ReservationStatus @default(PENDING)
  paymentStatus      PaymentStatus     @default(PENDING)
  paymentMethod      String?

  // Time fields
  scheduledAt        DateTime?
  reservationDate    DateTime?
  reservationTime    String?

  // Contact fields
  customerName       String?
  customerEmail      String?
  customerPhone      String?

  // Amount fields
  totalPrice         Decimal?          @db.Decimal(10, 2)
  amount             Decimal?          @db.Decimal(10, 2)
  currency           String            @default("EUR")

  // Additional fields
  notes              String?
  locationId         String?

  // Relations
  photos             ReservationPhoto[]
  reviews            Review[]
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle            Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mechanic           User?             @relation("MechanicReservations", fields: [mechanicId], references: [id])
  location           Location?         @relation(fields: [locationId], references: [id])

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model ReservationPhoto {
  id            String      @id @default(cuid())
  reservationId String
  url           String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model Tutorial {
  id          String             @id @default(cuid())
  title       String
  category    String
  difficulty  TutorialDifficulty
  videoUrl    String
  thumbnail   String?
  durationSec Int?
  favorites   Favorite[]
  createdAt   DateTime           @default(now())
}

model Favorite {
  userId     String
  tutorialId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@id([userId, tutorialId])
}

model Review {
  id            String      @id @default(cuid())
  userId        String
  reservationId String
  rating        Int
  comment       String?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  title  String
  body   String
  read   Boolean          @default(false)
  sentAt DateTime         @default(now())
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Location {
  id           String        @id @default(cuid())
  address      String
  lat          Float
  lng          Float
  routeUrl     String?
  reservations Reservation[]
}

model PaymentMethod {
  id        String @id @default(cuid())
  userId    String
  stripeRef String
  brand     String?
  last4     String?
  expMonth  Int?
  expYear   Int?
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Quote {
  id          String   @id @default(cuid())
  userId      String
  serviceType String
  estimated   Decimal  @db.Decimal(10, 2)
  currency    String   @default("EUR")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  body       String?
  imageUrl   String?
  sentAt     DateTime @default(now())
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String?
  vehicleId String?
  title     String
  message   String?
  dueDate   DateTime?
  dueAt     DateTime?
  severity  Severity @default(INFO)
  completed Boolean  @default(false)

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
