datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  MECHANIC
  ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

enum NotificationType {
  APPOINTMENT
  PROMO
  MAINTENANCE
  SYSTEM
}

enum Severity {
  INFO
  WARN
  CRITICAL
}

enum VehicleType {
  sedan
  suv
  truck
  minivan
  coupe
  other
}

enum TutorialCategory {
  entretien
  freins
  suspension
  batterie
  diagnostic
  eclairage
  fluide
  mecanique
}

enum TutorialDifficulty {
  facile
  moyen
  difficile
}

enum MaintenanceType {
  oil_change
  tire_rotation
  brake_service
  battery_replacement
  filter_change
  inspection
  repair
  other
}

enum DocumentType {
  registration
  insurance
  mot
  service_history
  warranty
  inspection
  other
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  passwordHash         String
  fullName             String
  phone                String?
  role                 Role            @default(USER)
  photoUrl             String?
  vehicles             Vehicle[]
  reservations         Reservation[]
  assignedReservations Reservation[]   @relation("MechanicReservations")
  reviews              Review[]
  favorites            Favorite[]
  quotes               Quote[]
  paymentMethod        PaymentMethod?
  passwordResetCodes   PasswordResetCode[]
  profileSettings      UserProfileSettings?
  notifications        Notification[]
  messagesSent         ChatMessage[]   @relation("MessagesSent")
  messagesReceived     ChatMessage[]   @relation("MessagesReceived")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Vehicle {
  id                 String              @id @default(cuid())
  userId             String
  name               String
  model              String
  year               Int
  mileage            Int
  type               VehicleType
  licensePlate       String?
  fuelType           String?
  vin                String?
  color              String?
  reservations       Reservation[]
  reminders          Reminder[]
  maintenanceRecords MaintenanceRecord[]
  documents          VehicleDocument[]
  insurance          VehicleInsurance?
  user               User                @relation(fields: [userId], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model MaintenanceRecord {
  id                String          @id @default(cuid())
  vehicleId         String
  type              MaintenanceType
  description       String
  mileage           Int
  cost              Decimal         @db.Decimal(10, 2)
  date              DateTime
  notes             String?
  nextMaintenanceKm Int?
  nextMaintenanceDate DateTime?
  attachments       Json?
  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model VehicleDocument {
  id         String       @id @default(cuid())
  vehicleId  String
  type       DocumentType
  title      String
  fileUrl    String
  expiryDate DateTime?
  uploadedAt DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  vehicle    Vehicle      @relation(fields: [vehicleId], references: [id])
}

model VehicleInsurance {
  id          String   @id @default(cuid())
  vehicleId   String   @unique
  provider    String
  policyNumber String
  startDate   DateTime
  endDate     DateTime
  coverage    String
  phoneNumber String?
  documentUrl String?
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReservationService {
  id              String   @id @default(cuid())
  slug            String   @unique
  label           String
  description     String?
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  slotTimes       String[]  @default([])
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Reservation {
  id          String             @id @default(cuid())
  userId      String
  vehicleId   String?
  mechanicId  String?
  serviceType String
  description String?
  status      ReservationStatus  @default(PENDING)
  scheduledAt DateTime
  photos      ReservationPhoto[]
  paymentId   String?
  amount      Decimal            @db.Decimal(10, 2)
  currency    String             @default("USD")
  locationId  String?
  reviews     Review[]
  user        User               @relation(fields: [userId], references: [id])
  vehicle     Vehicle?           @relation(fields: [vehicleId], references: [id])
  mechanic    User?              @relation("MechanicReservations", fields: [mechanicId], references: [id])
  location    Location?          @relation(fields: [locationId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ReservationPhoto {
  id            String      @id @default(cuid())
  reservationId String
  url           String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
}

model Tutorial {
  id           String             @id @default(cuid())
  title        String
  description  String
  category     TutorialCategory
  difficulty   TutorialDifficulty
  duration     Int
  views        Int                @default(0)
  rating       Float              @default(0)
  thumbnail    String
  videoUrl     String
  instructions Json
  tools        Json?
  favorites    Favorite[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Favorite {
  userId     String
  tutorialId String
  user       User     @relation(fields: [userId], references: [id])
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id])

  @@id([userId, tutorialId])
}

model Review {
  id            String      @id @default(cuid())
  userId        String
  reservationId String
  rating        Int
  comment       String?
  user          User        @relation(fields: [userId], references: [id])
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, reservationId])
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  title  String
  body   String
  read   Boolean          @default(false)
  sentAt DateTime         @default(now())
  user   User             @relation(fields: [userId], references: [id])
}

model Location {
  id           String        @id @default(cuid())
  address      String
  lat          Float
  lng          Float
  routeUrl     String?
  reservations Reservation[]
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  userId                String   @unique
  provider              String   @default("stripe")
  status                String   @default("not_configured")
  stripeRef             String
  brand                 String?
  last4                 String?
  expMonth              Int?
  expYear               Int?
  lastCheckoutSessionId String?
  lastSyncAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
}

model UserProfileSettings {
  userId             String   @id
  membershipLabel    String?
  verified           Boolean?
  memberSince        DateTime?
  preferredGarage    String?
  defaultVehicleLabel String?
  loyaltyPoints      Int?
  addressLine        String?
  city               String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])
}

model Quote {
  id          String   @id @default(cuid())
  userId      String
  serviceType String
  estimated   Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  body       String?
  imageUrl   String?
  sentAt     DateTime @default(now())
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id])
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id])
}

model Reminder {
  id        String   @id @default(cuid())
  vehicleId String
  title     String
  dueAt     DateTime
  severity  Severity @default(INFO)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}
